{
  "name": "somnia-agent-clob",
  "version": "0.1.0",
  "description": "Autonomous AI market-making agent on an on-chain CLOB, built on Somnia's Agentic L1.",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network somniaTestnet",
    "configure": "hardhat run scripts/configure.js --network somniaTestnet",
    "autonomous": "hardhat run scripts/autonomous.js --network somniaTestnet",
    "orchestrator": "node agent/orchestrator.js",
    "taker": "node scripts/taker.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.17"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@somnia-chain/reactivity-contracts": "^0.2.0",
    "dotenv": "^16.4.5"
  }
}
